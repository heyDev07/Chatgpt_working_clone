# Copy the relevant sections into backend/.env and frontend/.env.local

# ── backend/.env ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ai_assistant:ai_assistant@localhost:5433/ai_assistant
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

OPENAI_API_KEY=
# Optional: point the "openai" provider slot at any OpenAI-compatible endpoint,
# e.g. OpenRouter (https://openrouter.ai/api/v1) - useful for free-tier testing.
OPENAI_BASE_URL=
GEMINI_API_KEY=
DEFAULT_LLM_PROVIDER=openai
DEFAULT_OPENAI_MODEL=gpt-4o-mini
DEFAULT_GEMINI_MODEL=gemini-2.0-flash

QDRANT_URL=http://localhost:6333
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=ai_assistant
S3_SECRET_KEY=ai_assistant_minio
S3_BUCKET=documents
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

CORS_ORIGINS=http://localhost:3000

# ── frontend/.env.local ──────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
